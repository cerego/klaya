---
import Icon from '../components/Icon.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  fullTitle?: string;
  ogDescription?: string;
}

const { title, description = 'La conoscenza della vostra azienda, accessibile a chi serve.', fullTitle, ogDescription } = Astro.props;
const pageTitle = fullTitle ?? `${title} — Klaya`;
const pathname = Astro.url.pathname;
const isAbout = pathname === '/about' || pathname === '/about/';

const navLinks = [
  { label: 'Come funziona', href: '/#prodotto' },
  { label: 'Sicurezza', href: '/#sicurezza' },
  { label: "Casi d'uso", href: '/#casi-duso' },
  { label: 'Prezzi', href: '/#prezzi' },
];

const footerCols = [
  { heading: 'Prodotto', items: [
    { label: 'Come funziona', href: '/#prodotto' },
    { label: 'Sicurezza', href: '/#sicurezza' },
    { label: "Casi d'uso", href: '/#casi-duso' },
    { label: 'Prezzi', href: '/#prezzi' },
  ] },
  { heading: 'Azienda', items: [
    { label: 'Chi siamo', href: '/about' },
    { label: 'Early Adopter', href: '/#early-adopter' },
    { label: 'Contatti', href: '/#cta' },
  ] },
  { heading: 'Altro', items: [
    { label: 'Documentazione', href: '#' },
    { label: 'Blog', href: '#' },
    { label: 'Trust center', href: '#' },
    { label: 'Status', href: '#' },
  ] },
];
---

<!doctype html>
<html lang="it">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content="noindex, nofollow" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={ogDescription ?? description} />
    <link rel="icon" type="image/png" href="/logos/klaya-pictogram.png" />
    <title>{pageTitle}</title>
  </head>
  <body>

    <header class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo" aria-label="Klaya">
          <img src="/logos/klaya-logo.png" alt="Klaya" />
          <span class="nav-tagline">AI you can trust. Knowledge you can trace.</span>
        </a>
        <nav class="nav-links">
          {navLinks.map((l) => (
            <a href={l.href} class="nav-link">{l.label}</a>
          ))}
        </nav>
        <a href="#" class="btn btn-ghost btn-sm">Accedi</a>
        <a href="/#cta" class="btn btn-primary btn-sm">
          Parla con noi
          <Icon name="arrow-right" size={16} />
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-top">
        <div class="footer-brand">
          <img src="/logos/klaya-logo.png" alt="Klaya" />
          <p>AI you can trust. Knowledge you can trace.</p>
        </div>
        {footerCols.map((col) => (
          <div class="footer-col">
            <span class="footer-col-label">{col.heading}</span>
            {col.items.map((it) => (
              <a href={it.href} class:list={[{ 'footer-link--active': isAbout && it.href === '/about' }]}>{it.label}</a>
            ))}
          </div>
        ))}
      </div>
      <div class="footer-bottom">
        <span>© 2026 Klaya. Tutti i diritti riservati.</span>
        <span>Privacy · Termini · Cookie</span>
      </div>
    </footer>

  </body>
</html>

<style is:global>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(250, 249, 247, 0.82);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
  }

  .nav-inner {
    max-width: var(--container-xl);
    margin: 0 auto;
    height: 74px;
    padding: 0 28px;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .nav-logo { display: flex; flex-direction: column; align-items: flex-start; gap: 2px; line-height: 1; text-decoration: none; flex-shrink: 0; }
  .nav-logo img { height: 26px; width: auto; }
  .nav-tagline {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: var(--weight-medium);
    letter-spacing: 0.01em;
    color: var(--text-tertiary);
    white-space: nowrap;
  }

  .nav-links { display: flex; gap: 4px; flex: 1; }

  .nav-link {
    padding: 8px 12px;
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
    white-space: nowrap;
  }
  .nav-link:hover { color: var(--text-primary); }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    font-family: var(--font-sans);
    text-decoration: none;
    white-space: nowrap;
    border-radius: var(--radius-md);
    transition: background var(--duration-fast) var(--ease-standard), color var(--duration-fast) var(--ease-standard);
    flex-shrink: 0;
  }
  .btn-sm { height: 34px; padding: 0 14px; font-size: var(--text-body-sm); }
  .btn-lg { height: 52px; padding: 0 24px; font-size: var(--text-body-lg); border-radius: var(--radius-lg); }

  .btn-primary { background: var(--color-brand); color: var(--color-on-brand); font-weight: var(--weight-semibold); }
  .btn-primary:hover { background: var(--color-brand-hover); }

  .btn-secondary { background: var(--surface-card); color: var(--text-primary); border: 1px solid var(--border-default); font-weight: var(--weight-medium); }
  .btn-secondary:hover { background: var(--surface-hover); }

  .btn-ghost { background: transparent; color: var(--text-primary); font-weight: var(--weight-medium); }
  .btn-ghost:hover { background: var(--surface-hover); }

  .btn-inverse { background: var(--surface-inverse); color: var(--text-on-inverse); font-weight: var(--weight-semibold); }
  .btn-inverse:hover { background: var(--klaya-neutral-800); }

  .footer {
    border-top: 1px solid var(--border-subtle);
    background: var(--surface-card);
  }

  .footer-top {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 48px 28px 28px;
    display: grid;
    grid-template-columns: 1.4fr 1fr 1fr 1fr;
    gap: 28px;
  }

  .footer-brand img { height: 24px; width: auto; }
  .footer-brand p {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    color: var(--text-secondary);
    margin-top: 14px;
    max-width: 240px;
    line-height: 1.6;
  }

  .footer-col { display: flex; flex-direction: column; gap: 9px; }

  .footer-col-label {
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    font-weight: var(--weight-bold);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-tertiary);
    margin-bottom: 5px;
  }

  .footer-col a {
    font-family: var(--font-sans);
    font-size: var(--text-body-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast) var(--ease-standard);
  }
  .footer-col a:hover, .footer-col a.footer-link--active { color: var(--text-primary); }

  .footer-bottom {
    max-width: var(--container-xl);
    margin: 0 auto;
    padding: 18px 28px;
    border-top: 1px solid var(--border-subtle);
    display: flex;
    justify-content: space-between;
    font-family: var(--font-sans);
    font-size: var(--text-caption);
    color: var(--text-tertiary);
  }

  @media (max-width: 900px) {
    .nav-links { display: none; }
    .footer-top { grid-template-columns: 1fr 1fr; }
  }

  @media (max-width: 600px) {
    .nav-tagline { display: none; }
    .footer-top { grid-template-columns: 1fr; }
    .footer-bottom { flex-direction: column; gap: 8px; }
  }
</style>
